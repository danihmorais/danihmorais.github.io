{
  "productName": "MontaEdital - Gerador de Editais",
  "version": "1.0.2",
  "identifier": "com.danihmorais.montaedital",
  "build": {
    "beforeDevCommand": "npm run build-backend && npm run dev",
    "beforeBuildCommand": "npm run build-backend && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MontaEdital - Gerador de Editais",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}